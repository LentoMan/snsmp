    "version": "2.0.0",
    "tasks": [
        {
            "label": "run-ff-web-ext-twitter",
            "type": "shell",
            "options": {
                "shell": {
                    "executable": "cmd.exe",
                    "args": ["/d", "/c"]
                },
               "cwd": "${workspaceRoot}/snsmp_ff",
            },
            "command": "web-ext",
            "args": ["run", "--keep-profile-changes", "--firefox-profile","p:\\firefox\\Regular","--start-url","https://x.com/"],
        },
        {
            "label": "run-ff-web-ext-instagram",
